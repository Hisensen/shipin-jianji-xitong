# ============================================================
# 复制本文件为 .env 并填入真实 key
# ============================================================

# DeepSeek API（必填）：生成爆款标题、章节切分、视觉形式决策、金句
# 获取：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Pexels API（可选）：自动配图。免费
# 获取：https://www.pexels.com/api/
PEXELS_API_KEY=

# Whisper 模型（faster-whisper）
# 可选：tiny / base / small / medium / large-v3 / large-v3-turbo
WHISPER_MODEL=large-v3-turbo
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8

# Web 服务
HOST=127.0.0.1
PORT=8800
