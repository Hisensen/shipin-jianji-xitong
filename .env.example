# ============================================================
# 复制本文件为 .env 并填入真实 key
# ============================================================

# DeepSeek API（必填）：生成爆款标题、章节切分、视觉形式决策、金句
# 获取：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 图片来源：auto / openai / pexels
# auto = 优先用 OpenAI GPT Image 生成真实场景图，没有 OpenAI key 时再降级 Pexels
IMAGE_PROVIDER=auto

# OpenAI 图片生成（推荐）：直接生成“像亲身经历拍到的真实照片”
# 获取：https://platform.openai.com/
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_MODERATION=low
OPENAI_IMAGE_OUTPUT_FORMAT=jpeg
OPENAI_IMAGE_OUTPUT_COMPRESSION=85

# Pexels API（可选兜底）：自动配图。免费
# 获取：https://www.pexels.com/api/
PEXELS_API_KEY=

# 转录引擎：local / dashscope
# local     = 本地 faster-whisper（免费，准 85-90%）
# dashscope = 阿里云 paraformer（中文 95-97%，月免 600 分钟，超出 ¥0.0072/分钟）
TRANSCRIBE_PROVIDER=local

# 阿里云 DashScope（TRANSCRIBE_PROVIDER=dashscope 时必填）
# 获取：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=
DASHSCOPE_ASR_MODEL=paraformer-realtime-v2

# Whisper 模型（TRANSCRIBE_PROVIDER=local 时使用）
# 可选：tiny / base / small / medium / large-v3 / large-v3-turbo
WHISPER_MODEL=large-v3-turbo
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8

# Web 服务
HOST=127.0.0.1
PORT=8800
